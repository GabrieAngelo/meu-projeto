alert("seu texto");
   faz uma caixa de texto antes de entrar no site

let idade = "29";
    cria uma variavel para armazenar um valor, agora existe a variavel 
    "idade" que guarda "29"
    !(idade = 30;) pode ser usado para mudar uma variável após já feita
let idade = prompt("Qual é a sua idade?");
    faz uma caixa de texto para o usuário digitar um valor, e esse valor
    é armazenado na variavel "idade"
confirm("Você é maior de idade?");
    faz uma caixa de texto com a opção de "ok" ou "cancelar", e retorna
    true ou false, dependendo da escolha do usuário
    posso colocar let + a variavel para armazenar o valor retornado pelo 
    confirm EX: let Idade = confirm("Você é maior de idade?");

const PI = 3.14;
    cria uma constante, que não pode ser alterada depois de criada
    !(PI = 3.15;) não pode ser usado para mudar uma constante após já feita

